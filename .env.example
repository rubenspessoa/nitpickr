# Core runtime
DATABASE_URL=postgres://nitpickr:nitpickr@db:5432/nitpickr
NITPICKR_BASE_URL=https://your-public-host
NITPICKR_WEBHOOK_URL=https://your-public-host/webhooks/github
NITPICKR_SECRET_KEY=replace-with-a-long-random-secret

# OpenAI
OPENAI_API_KEY=<OPENAI_API_KEY>
OPENAI_BASE_URL=https://api.openai.com/v1
# Prefer gpt-5-mini for cost-effective reviews. If your account does not have
# access, set this to another supported model such as gpt-4.1.
OPENAI_MODEL=gpt-5-mini

# GitHub App
GITHUB_APP_ID=<GITHUB_APP_ID>
GITHUB_API_BASE_URL=https://api.github.com
# Comma-separated mention handles without '@'. Usually your GitHub App name.
GITHUB_BOT_LOGINS=nitpickr,getnitpickr
# Store the private key in your secret manager. Do not commit real keys.
# If you must use a single-line env var, use '\n' escapes for newlines.
GITHUB_PRIVATE_KEY=<GITHUB_APP_PRIVATE_KEY>
GITHUB_WEBHOOK_SECRET=replace-with-a-second-random-secret

# Runtime tuning
PORT=3000
NITPICKR_LOG_LEVEL=info
NITPICKR_WORKER_CONCURRENCY=4
NITPICKR_WORKER_POLL_INTERVAL_MS=5000
NITPICKR_JOB_STALE_AFTER_MS=900000
NITPICKR_WORKER_HEARTBEAT_INTERVAL_MS=5000
NITPICKR_READY_WORKER_STALE_AFTER_MS=15000

# Optional limits
# NITPICKR_REPOSITORY_ALLOWLIST=owner/repo-a,owner/repo-b
# NITPICKR_PROMPT_OPTIMIZATION_MODE=balanced
# DISCORD_WEBHOOK_URL=
